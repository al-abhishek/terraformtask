# Local .terraform directories
**/.terraform/*
 
# Terraform state files
*.tfstate
*.tfstate.*
 
# Crash logs
crash.log
crash.*.log
 
# Sensitive variable files
*.tfvars
*.tfvars.json
 
# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json
 
# Terraform plan files
*.tfplan
plan.out
 
# CLI configuration files
.terraformrc
terraform.rc
 
# Lock file (KEEP if working in team/projects)
# Usually recommended to COMMIT this file
# Uncomment below only if you explicitly don't want it
# .terraform.lock.hcl
 
# IDE/editor files
.vscode/
.idea/
 
# OS files
.DS_Store
Thumbs.db
 
# Logs
*.log
 
# Environment files
.env
.env.*
 
# Optional: Terragrunt cache
.terragrunt-cache/
 
# Optional: Terraform test files
terraform.tfvars
 
# Optional: tfsec/checkov output
*.sarif